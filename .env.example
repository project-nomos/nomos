# ─── API Provider ────────────────────────────────────────────────
# Select your API provider: anthropic, vertex, openrouter, ollama, custom
# NOMOS_API_PROVIDER=anthropic

# Option 1: Anthropic direct API
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Vertex AI (uses Application Default Credentials)
#   gcloud auth application-default login
# CLAUDE_CODE_USE_VERTEX=1
# GOOGLE_CLOUD_PROJECT=my-project
# CLOUD_ML_REGION=us-east5

# Option 3: OpenRouter (Anthropic models via OpenRouter)
# NOMOS_API_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...

# Option 4: Ollama (local models via LiteLLM proxy)
# NOMOS_API_PROVIDER=ollama
# ANTHROPIC_BASE_URL=http://localhost:4000

# ─── Claude Model ────────────────────────────────────────────────

NOMOS_MODEL=claude-opus-4-6

# ─── Database (required) ─────────────────────────────────────────

DATABASE_URL=postgresql://nomos:nomos@localhost:5432/nomos

# ─── Encryption (recommended) ───────────────────────────────────
# Encrypts integration secrets at rest in the database.
# Generate with: openssl rand -hex 32
# If not set, secrets are stored as plaintext (dev convenience).
# ENCRYPTION_KEY=

# ─── Embedding Model (optional) ──────────────────────────────────
# Used by the memory system. Defaults to gemini-embedding-001 via Vertex AI.
# Requires GOOGLE_CLOUD_PROJECT and ADC credentials.

# EMBEDDING_MODEL=gemini-embedding-001
# VERTEX_AI_LOCATION=global

# ─── Permission Mode (optional) ──────────────────────────────────
# Controls how tool usage is handled: default, acceptEdits, plan, dontAsk
# NOMOS_PERMISSION_MODE=acceptEdits

# ─── Smart Model Routing (optional) ─────────────────────────────
# Routes queries to different models based on complexity.
# Simple queries (greetings, short questions) use a cheaper/faster model.
# Complex queries (coding, reasoning, multi-step) use a more capable model.
# NOMOS_SMART_ROUTING=true
# NOMOS_MODEL_SIMPLE=claude-haiku-4-5
# NOMOS_MODEL_MODERATE=claude-sonnet-4-6
# NOMOS_MODEL_COMPLEX=claude-sonnet-4-6

# ─── Session & Runtime (optional) ────────────────────────────────
# Session scope: channel | sender | peer | channel-peer (default: channel)
# NOMOS_SESSION_SCOPE=channel

# Tool approval policy for dangerous operations (default: block_critical)
# TOOL_APPROVAL_POLICY=block_critical

# ─── Daemon (optional) ──────────────────────────────────────────
# DAEMON_PORT=8765
# HEARTBEAT_INTERVAL_MS=1800000

# ─── Discord Integration (optional) ─────────────────────────────
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_CHANNELS=              # comma-separated channel IDs
# DISCORD_ALLOWED_GUILDS=                # comma-separated guild IDs

# ─── Slack Integration (optional) ───────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...               # required for Socket Mode
# SLACK_ALLOWED_CHANNELS=                # comma-separated channel IDs

# ─── Slack User Mode (optional) ─────────────────────────────────
# Enables Nomos to act AS the authenticated user across Slack.
# Listens to DMs and @mentions, drafts responses for approval.
# Requires SLACK_APP_TOKEN (same as bot mode) for Socket Mode.
#
# Multi-workspace: run `nomos slack auth` to connect via OAuth.
# Requires a Slack app with OAuth redirect: http://localhost:9876/slack/oauth/callback
# SLACK_CLIENT_ID=your-client-id
# SLACK_CLIENT_SECRET=your-client-secret
#
# Legacy single workspace (use `nomos slack auth` instead):
# SLACK_USER_TOKEN=xoxp-...

# ─── Telegram Integration (optional) ────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHATS=                # comma-separated chat IDs

# ─── WhatsApp Integration (optional) ────────────────────────────
# WHATSAPP_ENABLED=true
# WHATSAPP_ALLOWED_CHATS=                # comma-separated JIDs (e.g., 15551234567@s.whatsapp.net,120363123456789012@g.us)

# ─── Google Workspace Integration (optional) ──────────────────
# Uses @googleworkspace/cli (gws) for Google Workspace access.
# Setup: gws auth setup (or configure client_secret.json manually)
# Auth: gws auth login (opens browser for OAuth)
# GWS_SERVICES=all                     # Services to expose via MCP (default: all)
#                                       # Options: drive,gmail,calendar,docs,sheets,slides,tasks,people,chat,forms,keep,meet
#                                       # Or "all" for everything
# GOOGLE_OAUTH_CLIENT_ID=...           # Optional: set via settings UI or gws auth setup
# GOOGLE_OAUTH_CLIENT_SECRET=...       # Optional: set via settings UI or gws auth setup

# ─── iMessage Integration (macOS only) ────────────────────────────
# Requires Full Disk Access and Messages.app running
# IMESSAGE_ENABLED=true
# IMESSAGE_ALLOWED_CHATS=+15551234567,chat123456  # comma-separated phone/email/chat IDs

# ─── Custom API Endpoint (optional) ──────────────────────────────
# For custom Anthropic-compatible API proxies (AWS Bedrock, Azure, etc.)
# NOMOS_API_PROVIDER=custom
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# ANTHROPIC_API_KEY=your-proxy-key

# ─── Multi-Agent Teams (optional) ────────────────────────────────
# Enable team mode to decompose complex tasks across parallel worker agents.
# Trigger with /team prefix in messages.
# NOMOS_TEAM_MODE=true
# NOMOS_MAX_TEAM_WORKERS=3

# ─── Adaptive Memory (optional) ──────────────────────────────────
# Enable knowledge extraction and user model learning.
# When enabled, the agent extracts facts, preferences, and corrections
# from conversations and builds a user model over time.
# NOMOS_ADAPTIVE_MEMORY=true
# NOMOS_EXTRACTION_MODEL=claude-haiku-4-5    # Model for extraction (default: haiku)

# ─── Image Generation (optional) ─────────────────────────────────
# Generate images using Google's Gemini model.
# Requires a Gemini API key from https://aistudio.google.com/apikey
# NOMOS_IMAGE_GENERATION=true
# GEMINI_API_KEY=your-gemini-api-key
# NOMOS_IMAGE_GENERATION_MODEL=gemini-3-pro-image-preview  # Model for image generation
# NOMOS_VIDEO_GENERATION=true
# NOMOS_VIDEO_GENERATION_MODEL=veo-3.0-generate-preview    # Model for video generation

# ─── Browser Fetch (optional) ────────────────────────────────────
# BROWSER_FETCH_ALLOW_LOCAL=1           # Allow fetching localhost URLs
